# ── Bitvavo API ──────────────────────────────────────────────────────────────
# Maak een sleutel aan via: Bitvavo > Instellingen > API > Nieuwe sleutel
# Fase 1+2: alleen 'Lezen' rechten nodig (geen trade-rechten)
BITVAVO_API_KEY=jouw_api_key_hier
BITVAVO_API_SECRET=jouw_api_secret_hier

# ── Trading instellingen ──────────────────────────────────────────────────────
# Kommagescheiden handelsparen
TRADING_MARKETS=BTC-EUR,ETH-EUR
# Candle interval: 1m 5m 15m 30m 1h 2h 4h 6h 8h 12h 1d
CANDLE_INTERVAL=1h
# Hoe vaak de strategie controleert (in minuten)
CHECK_INTERVAL_MINUTES=60

# ── Paper trading ─────────────────────────────────────────────────────────────
# Virtueel startkapitaal in EUR
PAPER_STARTING_CAPITAL=1000.0
# Fractie van cash die per trade ingezet wordt (0.95 = 95%)
PAPER_TRADE_FRACTION=0.95

# ── MQTT (Home Assistant) ─────────────────────────────────────────────────────
# Laat leeg om MQTT uit te schakelen
MQTT_HOST=192.168.1.x
MQTT_PORT=1883
MQTT_USER=mqtt_gebruikersnaam
MQTT_PASS=mqtt_wachtwoord
# Prefix voor MQTT topics
MQTT_PREFIX=bitvavo
